  "cards": [
    {
      "id": "dorf-01",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 5,
      "text_kmr": "Şaşfehmiyeke kevn dîsa geş dibe, tu bi aramî çareser dikî – 5 xane paşve here.",
      "text_de": "Ein altes Missverständnis flammt wieder auf, du klärst es in Ruhe – 5 Felder zurück.",
      "text_tr": "Eski bir yanlış anlaşılma yeniden alevlenir, sakince çözersin – 5 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-02",
      "bereich": "dorf",
      "typ": "vorwaerts",
      "wert": 1,
      "text_kmr": "Sibehê çaya taze, gava te sivik – 1 xane pêşve here.",
      "text_de": "Frischer Çay am Morgen, leichter Schritt – 1 Feld vor.",
      "text_tr": "Sabah taze çay, adımların hafif – 1 kare ileri.",
      "audio": ""
    },
    {
      "id": "dorf-03",
      "bereich": "dorf",
      "typ": "vorwaerts",
      "wert": 2,
      "text_kmr": "Cîranê te te li traktorê siwar dike – 2 xane pêşve here.",
      "text_de": "Der Nachbar nimmt dich auf dem Traktor mit – 2 Felder vor.",
      "text_tr": "Komşun seni traktöre alır – 2 kare ileri.",
      "audio": ""
    },
    {
      "id": "dorf-04",
      "bereich": "dorf",
      "typ": "vorwaerts",
      "wert": 2,
      "text_kmr": "Dema nan tê pijandin, nanekî germ didine te – 2 xane pêşve here.",
      "text_de": "Beim Brotbacken bekommst du ein warmes Fladenbrot mit – 2 Felder vor.",
      "text_tr": "Ekmek pişerken sana sıcak bir pide verirler – 2 kare ileri.",
      "audio": ""
    },
    {
      "id": "dorf-05",
      "bereich": "dorf",
      "typ": "vorwaerts",
      "wert": 3,
      "text_kmr": "Dawetek di gund re derbas dibe, herkes te dans dike pêş – 3 xane pêşve here.",
      "text_de": "Eine Hochzeit zieht durchs Dorf, alle tanzen dich nach vorn – 3 Felder vor.",
      "text_tr": "Köyde bir düğün var, herkes seni öne doğru dans ettirir – 3 kare ileri.",
      "audio": ""
    },
    {
      "id": "dorf-06",
      "bereich": "dorf",
      "typ": "vorwaerts",
      "wert": 1,
      "text_kmr": "Dapîra te tûyên zuwa dide te – 1 xane pêşve here.",
      "text_de": "Die Großmutter steckt dir getrocknete Maulbeeren zu – 1 Feld vor.",
      "text_tr": "Nine sana kuru dut verir – 1 kare ileri.",
      "audio": ""
    },
    {
      "id": "dorf-07",
      "bereich": "dorf",
      "typ": "vorwaerts",
      "wert": 4,
      "text_kmr": "Erebeya postê bi aliyê te ve diçe, tu siwar dibî – 4 xane pêşve here.",
      "text_de": "Der Postwagen fährt deine Richtung, du steigst auf – 4 Felder vor.",
      "text_tr": "Posta arabası tam senin yönüne gider, atlarsın – 4 kare ileri.",
      "audio": ""
    },
    {
      "id": "dorf-08",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 1,
      "text_kmr": "Tu alîkariya girtina kerekî dikî – 1 xane paşve here.",
      "text_de": "Du hilfst, einen Esel einzufangen – 1 Feld zurück.",
      "text_tr": "Bir eşeği yakalamaya yardım edersin – 1 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-09",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 2,
      "text_kmr": "Li ser kaniyê sohbeteke dirêj – 2 xane paşve here.",
      "text_de": "Langes Schwätzchen am Brunnen – 2 Felder zurück.",
      "text_tr": "Çeşme başında uzun bir sohbet – 2 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-10",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 1,
      "text_kmr": "Tu selikê ji bîr dikî û vedigerî – 1 xane paşve here.",
      "text_de": "Du vergisst den Korb und gehst noch einmal zurück – 1 Feld zurück.",
      "text_tr": "Sepeti unutursun ve geri dönersin – 1 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-11",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 3,
      "text_kmr": "Nîqaşek li ser mafê mêrgê te radiwestîne – 3 xane paşve here.",
      "text_de": "Ein Streit ums Weiderecht hält dich auf – 3 Felder zurück.",
      "text_tr": "Otlak hakkı yüzünden bir tartışma seni oyalar – 3 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-12",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 2,
      "text_kmr": "Seyê hewşê dixwaze bi te re bilîze – 2 xane paşve here.",
      "text_de": "Der Hofhund will unbedingt spielen – 2 Felder zurück.",
      "text_tr": "Avlu köpeği illa oynamak ister – 2 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-13",
      "bereich": "dorf",
      "typ": "rueckwaerts",
      "wert": 3,
      "text_kmr": "Tu di berhevkirina hinaran de diqede – 3 xane paşve here.",
      "text_de": "Du verzettelst dich beim Granatapfel-Pflücken – 3 Felder zurück.",
      "text_tr": "Nar toplarken oyalanırsın – 3 kare geri.",
      "audio": ""
    },
    {
      "id": "dorf-14",
      "bereich": "dorf",
      "typ": "aussetzen",
      "wert": null,
      "text_kmr": "Serdaneke dirêj li mala malbatê – carekê bisekine.",
      "text_de": "Langer Besuch bei der Familie – einmal aussetzen.",
      "text_tr": "Ailede uzun bir ziyaret – bir tur bekle.",
      "audio": ""
    },
    {
      "id": "dorf-15",
      "bereich": "dorf",
      "typ": "aussetzen",
      "wert": null,
      "text_kmr": "Çaydank hîn nîvco ye, tu rûdinî – carekê bisekine.",
      "text_de": "Die Teekanne ist noch halb voll, du bleibst sitzen – einmal aussetzen.",
      "text_tr": "Çaydanlık daha yarı dolu, oturup kalırsın – bir tur bekle.",
      "audio": ""
    },
    {
      "id": "dorf-16",
      "bereich": "dorf",
      "typ": "erneut",
      "wert": null,
      "text_kmr": "Mizgîniyek ji gund tê – dîsa zarî bavêje.",
      "text_de": "Gute Nachricht aus dem Dorf – noch einmal würfeln.",
      "text_tr": "Köyden güzel bir haber – hemen tekrar zar at.",
      "audio": ""
    },
    {
      "id": "dorf-17",
      "bereich": "dorf",
      "typ": "erneut",
      "wert": null,
      "text_kmr": "Bayê piştê û kêfa te baş – dîsa zarî bavêje.",
      "text_de": "Rückenwind und gute Laune – noch einmal würfeln.",
      "text_tr": "Rüzgâr arkanda, keyfin yerinde – hemen tekrar zar at.",
      "audio": ""
    },
    {
      "id": "dorf-18",
      "bereich": "dorf",
      "typ": "vor_zu_naechstem",
      "wert": null,
      "text_kmr": "Tu xwe digihînî cîranê ku jixwe pêştir e – here ba yê li pêş.",
      "text_de": "Du schließt dich dem Nachbarn an, der schon weiter ist – vor zum Nächsten.",
      "text_tr": "Daha ileride olan komşuna katılırsın – önündekine ilerle.",
      "audio": ""
    },
    {
      "id": "dorf-19",
      "bereich": "dorf",
      "typ": "tausch_hinterster",
      "wert": null,
      "text_kmr": "Tu vedigerî û yê herî hêdî tînî – cih bi yê dawî re biguhere.",
      "text_de": "Du kehrst um und holst den Langsamsten ab – Tausch mit dem Letzten.",
      "text_tr": "Geri dönüp en yavaş olanı alırsın – sonuncu ile yer değiştir.",
      "audio": ""
    },
    {
      "id": "dorf-20",
      "bereich": "dorf",
      "typ": "tausch_fuehrender",
      "wert": null,
      "text_kmr": "Kurterêyek di nav zeviyan re te dibe pêş – cih bi pêşeng re biguhere.",
      "text_de": "Eine Abkürzung über die Felder bringt dich nach vorn – Tausch mit dem Führenden.",
      "text_tr": "Tarlalardan bir kestirme seni en öne taşır – lider ile yer değiştir.",
      "audio": ""
    },
    {
      "id": "felder-01",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 6,
      "text_kmr": "",
      "text_de": "Ein Gewitter jagt die Herde auseinander – du läufst weit zurück, um sie zu sammeln.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-02",
      "bereich": "felder",
      "typ": "vorwaerts",
      "wert": 1,
      "text_kmr": "",
      "text_de": "Die Sonne wärmt den Pfad – 1 Feld vor.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-03",
      "bereich": "felder",
      "typ": "vorwaerts",
      "wert": 2,
      "text_kmr": "",
      "text_de": "Der Hütehund treibt dich flott voran – 2 Felder vor.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-04",
      "bereich": "felder",
      "typ": "vorwaerts",
      "wert": 2,
      "text_kmr": "",
      "text_de": "Frisches Quellwasser gibt neue Kraft – 2 Felder vor.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-05",
      "bereich": "felder",
      "typ": "vorwaerts",
      "wert": 3,
      "text_kmr": "",
      "text_de": "Trockener, fester Boden – du kommst gut voran, 3 Felder vor.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-06",
      "bereich": "felder",
      "typ": "vorwaerts",
      "wert": 1,
      "text_kmr": "",
      "text_de": "Ein Lamm tapst dir freudig hinterher – 1 Feld vor.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-07",
      "bereich": "felder",
      "typ": "vorwaerts",
      "wert": 4,
      "text_kmr": "",
      "text_de": "Jemand nimmt dich auf dem Heuwagen mit – 4 Felder vor.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-08",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 1,
      "text_kmr": "",
      "text_de": "Ein Schaf hat sich verlaufen – 1 Feld zurück.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-09",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 2,
      "text_kmr": "",
      "text_de": "Du flickst schnell den Weidezaun – 2 Felder zurück.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-10",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 1,
      "text_kmr": "",
      "text_de": "Matschige Stelle, du suchst einen Umweg – 1 Feld zurück.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-11",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 3,
      "text_kmr": "",
      "text_de": "Plötzlicher Regen, du suchst Schutz unterm Baum – 3 Felder zurück.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-12",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 2,
      "text_kmr": "",
      "text_de": "Die Herde will partout nicht weiter – 2 Felder zurück.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-13",
      "bereich": "felder",
      "typ": "rueckwaerts",
      "wert": 3,
      "text_kmr": "",
      "text_de": "Du sammelst Kräuter und vergisst die Zeit – 3 Felder zurück.",
      "text_tr": "",
      "audio": ""
    },
    {
      "id": "felder-14",
